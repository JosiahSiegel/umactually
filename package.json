{
  "name": "umactually",
  "version": "0.1.0",
  "description": "Provider-agnostic PR review action with redaction and SonarQube import.",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "umactually-pr-review": "bin/umactually-pr-review.mjs"
  },
  "files": [
    "dist",
    "bin",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:scenario": "vitest --project scenario",
    "test:config": "vitest --run --project unit test/unit/config-extended.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "ncc build src/index.ts -o dist && ncc build src/cli.ts -o dist-tmp && node scripts/post-bundle.mjs",
    "bundle": "npm run build",
    "check:dist-freshness": "node scripts/check-dist-freshness.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vercel/ncc": "0.38.4",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}